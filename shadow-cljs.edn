{:source-paths ["src" "test"]

 :dependencies
 [[quil "3.1.0"]]

 :dev-http {8080 "public"}

 :builds
 {:app
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:main {:init-fn game.core/init}}
   :devtools   {:after-load game.core/reload}}

  :test
  {:target    :node-test
   :output-to "out/test/tests.js"
   :main      game.test-runner/main}}}
